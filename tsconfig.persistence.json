{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist-test",
    "jsx": "react-jsx"
  },
  "include": [
    "src/state.ts",
    "src/types.ts",
    "src/typora-theme-registry.ts"
  ]
}
