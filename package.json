{
  "name": "block-first-notebook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:typora-css && vite --host 127.0.0.1",
    "build": "pnpm build:typora-css && tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:editor": "node scripts/editor-smoke.mjs",
    "test:view-model": "node scripts/workspace-view-model-smoke.mjs",
    "test:markdown": "node scripts/markdown-import-smoke.mjs",
    "test:markdown-folder": "node scripts/markdown-folder-import-smoke.mjs",
    "test:markdown-folder:stress": "node scripts/markdown-folder-stress.mjs",
    "test:theme": "node scripts/theme-smoke.mjs",
    "test:persistence": "rm -rf dist-test && tsc -p tsconfig.persistence.json && printf '{\"type\":\"commonjs\"}' > dist-test/package.json && node scripts/persistence-queue-smoke.mjs && rm -rf dist-test",
    "build:typora-css": "node scripts/typora-css-prefixer.mjs && node scripts/generate-typora-mark-bridge.mjs",
    "audit:typora-themes": "node scripts/audit-typora-themes.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "latest",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-code-block-lowlight": "^3.26.1",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-list": "^3.26.1",
    "@tiptap/extension-mathematics": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@vitejs/plugin-react": "latest",
    "katex": "^0.17.0",
    "lowlight": "^3.3.0",
    "lucide-react": "latest",
    "marked": "^18.0.5",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.9",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "postcss-safe-parser": "^7.0.1"
  },
  "packageManager": "pnpm@11.5.1"
}
